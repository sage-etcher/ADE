	-rm -f ./$(DEPDIR)/u2nsfd.Po
	-rm -f ./$(DEPDIR)/unskew-hd-image.Po
	-rm -f Makefile
distclean-am: clean-am distclean-compile distclean-generic \
	distclean-tags

