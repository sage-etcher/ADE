	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(adedatadir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(adedatadir)" || exit $$?; \
	done

uninstall-dist_adedataDATA:
