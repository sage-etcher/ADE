install-dist_adeconfDATA: $(dist_adeconf_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_adeconf_DATA)'; test -n "$(adeconfdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(adeconfdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(adeconfdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(adeconfdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(adeconfdir)" || exit $$?; \
	done

uninstall-dist_adeconfDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_adeconf_DATA)'; test -n "$(adeconfdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(adeconfdir)'; $(am__uninstall_files_from_dir)
install-dist_adedataDATA: $(dist_adedata_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_adedata_DATA)'; test -n "$(adedatadir)" || list=; \
